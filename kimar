<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة الألعاب الاحترافية</title>
    <style>
        :root {
            --bg-color: #121212;
            --panel-bg: #1e1e1e;
            --gold: #d4af37;
            --text-light: #ffffff;
            --text-muted: #aaaaaa;
        }
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-light);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            width: 100%;
            max-width: 800px;
            background-color: var(--panel-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            border: 1px solid #333;
        }
        h1, h2, h3 {
            color: var(--gold);
            text-align: center;
        }
        .section {
            display: none;
        }
        .active {
            display: block;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-muted);
        }
        input, select, button {
            width: 100%;
            padding: 12px;
            border-radius: 6px;
            border: 1px solid #444;
            background-color: #2a2a2a;
            color: white;
            font-size: 16px;
            box-sizing: border-box;
        }
        input:focus, select:focus {
            outline: none;
            border-color: var(--gold);
        }
        button {
            background-color: var(--gold);
            color: #000;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
            margin-top: 10px;
        }
        button:hover {
            background-color: #b5952f;
        }
        .card {
            background-color: #2a2a2a;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-right: 4px solid var(--gold);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        th, td {
            padding: 10px;
            border-bottom: 1px solid #444;
            text-align: right;
        }
        th {
            color: var(--gold);
        }
        .header-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #333;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .logout-btn {
            width: auto;
            background-color: #ff4444;
            color: white;
            padding: 8px 15px;
        }
    </style>
</head>
<body>

<div class="container">
    
    <!-- شاشة تسجيل الدخول -->
    <div id="loginSection" class="section active">
        <h1>VIP كازينو</h1>
        <p style="text-align: center; color: var(--text-muted);">يرجى إدخال رقم الهاتف للدخول إلى المنصة</p>
        <div class="form-group">
            <label for="phoneNumber">رقم الهاتف:</label>
            <input type="tel" id="phoneNumber" placeholder="مثال: 70233833">
        </div>
        <button onclick="login()">تسجيل الدخول</button>
    </div>

    <!-- شاشة لوحة تحكم الإدارة (الآدمن) -->
    <div id="adminSection" class="section">
        <div class="header-bar">
            <h2>لوحة تحكم الإدارة (مراقبة الدولة)</h2>
            <button class="logout-btn" onclick="logout()">خروج</button>
        </div>
        
        <div class="card">
            <h3>تحديد نتيجة سباق الخيل مسبقاً</h3>
            <div class="form-group">
                <label for="winningHorse">اختر الحصان الفائز للسباق القادم:</label>
                <select id="winningHorse">
                    <option value="horse1">الحصان رقم 1 (البرق)</option>
                    <option value="horse2">الحصان رقم 2 (الرعد)</option>
                    <option value="horse3">الحصان رقم 3 (العاصفة)</option>
                    <option value="horse4">الحصان رقم 4 (السهم)</option>
                </select>
            </div>
            <button onclick="setWinner()">تأكيد النتيجة بالنظام</button>
        </div>

        <div class="card">
            <h3>مراقبة اللاعبين النشطين</h3>
            <table>
                <thead>
                    <tr>
                        <th>رقم الهاتف</th>
                        <th>الرصيد الحالي</th>
                        <th>الرهان الحالي (خيل)</th>
                        <th>حالة البوكر</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <!-- بيانات وهمية للمراقبة -->
                    <tr>
                        <td>03112233</td>
                        <td>$1,500</td>
                        <td>الحصان 2 ($100)</td>
                        <td>طاولة VIP</td>
                    </tr>
                    <tr>
                        <td>71445566</td>
                        <td>$300</td>
                        <td>الحصان 4 ($50)</td>
                        <td>طاولة عادية</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- شاشة المستخدم العادي -->
    <div id="userSection" class="section">
        <div class="header-bar">
            <h2>صالة الألعاب</h2>
            <button class="logout-btn" onclick="logout()">خروج</button>
        </div>
        <p>مرحباً بك، رصيدك الحالي: <strong style="color:var(--gold);">$500</strong></p>

        <div class="card">
            <h3>سباق الخيول المباشر</h3>
            <p style="color: var(--text-muted);">ضع رهانك على الحصان الرابح في السباق القادم.</p>
            <div class="form-group">
                <label>اختر حصانك:</label>
                <select id="userBet">
                    <option value="horse1">الحصان رقم 1 (البرق)</option>
                    <option value="horse2">الحصان رقم 2 (الرعد)</option>
                    <option value="horse3">الحصان رقم 3 (العاصفة)</option>
                    <option value="horse4">الحصان رقم 4 (السهم)</option>
                </select>
            </div>
            <div class="form-group">
                <label>مبلغ الرهان ($):</label>
                <input type="number" min="1" max="500" value="50">
            </div>
            <button onclick="placeBet()">تأكيد الرهان</button>
        </div>

        <div class="card">
            <h3>صالة البوكر (Texas Hold'em)</h3>
            <p style="color: var(--text-muted);">انضم إلى طاولات البوكر مع لاعبين من حول العالم.</p>
            <button style="background-color: #2a2a2a; color: var(--gold); border: 1px solid var(--gold);">الانضمام لطاولة عادية (Buy-in $50)</button>
            <button style="background-color: var(--gold); color: #000;">الانضمام لطاولة VIP (Buy-in $500)</button>
        </div>
    </div>

</div>

<script>
    // التحكم بالواجهات
    function login() {
        const phone = document.getElementById('phoneNumber').value;
        const loginSec = document.getElementById('loginSection');
        const adminSec = document.getElementById('adminSection');
        const userSec = document.getElementById('userSection');

        if (phone.trim() === '') {
            alert('يرجى إدخال رقم الهاتف');
            return;
        }

        loginSec.classList.remove('active');

        // التحقق من رقم الآدمن
        if (phone === '70233833') {
            adminSec.classList.add('active');
        } else {
            userSec.classList.add('active');
        }
    }

    function logout() {
        document.getElementById('adminSection').classList.remove('active');
        document.getElementById('userSection').classList.remove('active');
        document.getElementById('loginSection').classList.add('active');
        document.getElementById('phoneNumber').value = '';
    }

    // وظائف محاكاة للأزرار
    function setWinner() {
        const horse = document.getElementById('winningHorse').options[document.getElementById('winningHorse').selectedIndex].text;
        alert('تم تثبيت النتيجة في قاعدة البيانات. الفائز سيكون: ' + horse);
    }

    function placeBet() {
        const horse = document.getElementById('userBet').options[document.getElementById('userBet').selectedIndex].text;
        alert('تم وضع رهانك بنجاح على: ' + horse + '\nبانتظار بدء السباق...');
    }
</script>

</body>
</html>
